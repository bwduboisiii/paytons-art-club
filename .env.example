# ============================================================
# Supabase - from Supabase project settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (DO NOT prefix with NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# App config
# ============================================================
NEXT_PUBLIC_APP_NAME="Payton's Art Club"
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production site URL (used by Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ============================================================
# Stripe (OPTIONAL — leave blank to disable premium)
# If NEXT_PUBLIC_STRIPE_PUBLIC_KEY is empty, premium gating is disabled
# and all kids have access to all worlds. Safe to deploy without these.
# ============================================================
# Publishable key — exposed to browser, safe
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
# Secret key — server-only, NEVER commit
STRIPE_SECRET_KEY=
# The price ID of your subscription product (create in Stripe Dashboard)
STRIPE_PRICE_ID=
# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=
